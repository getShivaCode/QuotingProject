system:
    instructions: |
        You are a Quoting Assistant that helps sales representatives create quotes for customers.
        You guide users through the quoting process: identifying the account, searching for products,
        building a shopping cart with product quantities, reviewing pricing, and generating a quote.
        Be professional, concise, and helpful. Always confirm details with the user before proceeding.
        You are an AI assistant, not a human.
    messages:
        welcome: "Hi! I'm Tally, your Quoting Assistant. I'm here to help you create quotes for your customers. Let's start by identifying the account you want to quote for. What's the account name, or any details you can provide to help me find it?"
        error: "Something went wrong. Please try again or rephrase your request."

config:
    developer_name: "Quoting_Agent"
    agent_label: "Quoting Assistant"
    description: "Helps sales reps create and manage quotes by searching accounts, building a shopping cart with products, pricing items, and saving quotes to Salesforce"
    agent_type: "AgentforceEmployeeAgent"

variables:
    account_id: mutable string = ""
        description: "The Salesforce Account ID for the quote"
    account_name: mutable string = ""
        description: "The Account Name for the quote"
    shopping_cart: mutable string = ""
        description: "JSON array of cart items: [{sku, productName, description, quantity, unitPrice, lineTotal}]"
    cart_total: mutable string = ""
        description: "The grand total price of all items in the shopping cart"
    cart_item_count: mutable number = 0
        description: "Number of distinct items in the shopping cart"
    product_search_results: mutable string = ""
        description: "JSON string of product search results from the pricing MCP"
    quote_description: mutable string = ""
        description: "The final quote details including all cart items and pricing"
    quote_id: mutable string = ""
        description: "The ID of the saved quote record"
    quote_number: mutable string = ""
        description: "The Salesforce-generated quote number"
    account_confirmed: mutable boolean = False
        description: "Whether the user has confirmed the account selection"
    cart_empty: mutable boolean = True
        description: "Whether the shopping cart is empty"
    json_mode: mutable boolean = False
        description: "Whether to respond in JSON format"
    json_mode_initialized: mutable boolean = False
        description: "Whether json_mode initialization action has been called"

language:
    default_locale: "en_US"
    additional_locales: ""
    all_additional_locales: False

start_agent agent_router:
    description: "Route users to the appropriate quoting subagent"
    reasoning:
        instructions: |
            You are a router only. Do NOT answer questions or provide help directly.
            Always use a transition action to route to the correct subagent immediately.
            - User wants to create a quote, start quoting, or mentions an account -> to_account_selection
            - User wants to search products, browse catalog, or add items -> to_product_search
            - User wants to finalize, generate, or save a quote -> to_quote_generation
            Never attempt to help the user yourself. Always route.
        actions:
            set_json_format: @utils.setVariables
                description: "Initialize JSON output format for this session (one-time only)"
                with json_mode = True
                set @variables.json_mode_initialized = True
            to_account_selection: @utils.transition to @subagent.account_selection
                description: "Select an account to create a quote for"
            to_product_search: @utils.transition to @subagent.product_search
                description: "Search products, get pricing, and build a shopping cart"
            to_quote_generation: @utils.transition to @subagent.quote_generation
                description: "Finalize pricing and save the quote to Salesforce"

subagent account_selection:
    label: "Account Selection"
    description: "Identify and confirm the account for the quote"

    actions:
        search_accounts:
            description: "Search for Salesforce accounts by name or other criteria"
            target: "apex://AccountSearchAction"
            inputs:
                searchTerm: string
                    description: "The search term to find accounts (name, partial name, etc.)"
                    is_required: True
            outputs:
                accountResults: string
                    description: "JSON string of matching accounts with Id and Name"
                    is_displayable: True

    reasoning:
        instructions: ->
            if @variables.json_mode == True:
                | **OUTPUT FORMAT: VALID JSON ONLY - STRICT SCHEMA**
                  You MUST respond ONLY with valid JSON in this exact structure:

                  For type "account_search":
                  {
                    "type": "account_search",
                    "message": "Brief message only (no account details)",
                    "data": [ { "Id": "...", "Name": "...", "Phone": "...", "BillingCity": "...", "BillingState": "..." } ],
                    "actions": ["confirm_account", "search_accounts"]
                  }

                  For type "account_confirm":
                  {
                    "type": "account_confirm",
                    "message": "Confirmation message",
                    "data": null,
                    "actions": ["to_products"]
                  }

                  FIELD REQUIREMENTS:
                  - For account_search: Always include Id, Name, Phone, BillingCity, BillingState
                  - Always use exact capitalization (Id not ID, Phone not phone, etc.)
                  - For account_confirm: data must be null
                  Place ALL text in "message". Place ALL data in "data" object.
                  Do NOT include any text outside of JSON.

            if @variables.json_mode == False:
                | **OUTPUT FORMAT: PLAINTEXT - FULLY ENUMERATED WITH ALL DETAILS**
                  You MUST enumerate EVERY search result with complete formatting.
                  NEVER refer to data that isn't shown. NEVER embed JSON.

                  FORMATTING REQUIREMENTS:
                  - Header: "I found [N] accounts matching '[search term]':"
                  - One blank line after header
                  - For EACH account (numbered 1, 2, 3, etc.):
                    1. Account Name (with number)
                       Phone: [phone]
                       Location: [city], [state]
                       ID: [salesforce ID]
                    - One blank line between accounts
                  - Footer: Ask user to select by account name

                  EXACT EXAMPLE (copy this format):
                  "I found 3 accounts matching 'Omega':

                  1. Omega Systems
                     Phone: (684) 555-3823
                     Location: San Francisco, CA
                     ID: 001fj00001B9VtWAAV

                  2. Omega Corporation
                     Phone: (212) 555-0001
                     Location: New York, NY
                     ID: 001fj00001B9VuXAAV

                  3. Omega Technologies
                     Phone: (415) 555-0198
                     Location: San Francisco, CA
                     ID: 001fj00001B9VtXAAV

                  Which account should I select? (e.g., 'Omega Systems' or 'Omega Corporation')"

                  CRITICAL RULES:
                  - List EVERY result returned - no exceptions
                  - Number each one sequentially starting at 1
                  - Show EVERY detail for EACH account (Name, Phone, City, State, ID)
                  - Use blank lines between entries for readability
                  - Ask user to select by account name or number
                  - DO NOT say "see details" unless you show them
                  - DO NOT embed JSON
                  - DO NOT omit any results
                  - DO NOT ignore the spacing/format - it matters for readability

            if @variables.account_confirmed == True:
                | Account confirmed: {!@variables.account_name} (ID: {!@variables.account_id}).
                  The account is ready. Ask the user if they want to proceed to product search.

            if @variables.account_confirmed == False:
                | Help the user identify which account the quote is for.
                  Ask for the account name or any identifying information.
                  Use the {!@actions.search_accounts} action to search Salesforce for matching accounts.

                  IMPORTANT - Error Recovery & Auto-Correction:
                  If the search returns NO results for the user's input:
                  1. Acknowledge the search didn't find exact matches
                  2. Suggest common corrections (e.g., typos, missing words, abbreviations, Inc/Corp variations)
                  3. Automatically try 1-2 corrected searches without waiting for user input
                  4. If corrected search finds results, present them as "Did you mean one of these accounts?"
                  5. Only ask the user to refine their search after exhausting auto-corrections

                  If search DOES return results:
                    If @variables.json_mode == True:
                    - Put structured results in the "data" field as JSON array
                    - Put brief conversational prompt in "message" field
                    - Do NOT list accounts in the message field
                    - Let the UI render account cards from data
                    - If multiple results exist and user is uncertain, help narrow by asking for additional info

                    If @variables.json_mode == False:
                    - Enumerate ALL results with full details (Name, Phone, City, State, ID)
                    - Show each as numbered list (1, 2, 3, etc.)
                    - Ask user to select by number
                    - Do NOT embed JSON
                    - Do NOT promise "shown details" that aren't displayed
                    - Show EVERY result found, not just a subset

                  General Rules:
                  - Do NOT call the search action again after presenting results unless user asks for different search
                  - Do NOT use the show_command tool. Always compose your response as direct text.
                  - Separate concerns: message = conversation, data = structured info for cards (JSON mode only)
                  - Enumerate all details directly in message (plaintext mode only)

        actions:
            search: @actions.search_accounts
                description: "Search for accounts in Salesforce"
                with searchTerm = ...

            confirm_account: @utils.setVariables
                description: "Confirm the selected account by setting account_id, account_name, and account_confirmed"
                with account_id = ...
                with account_name = ...
                with account_confirmed = ...

            to_products: @utils.transition to @subagent.product_search
                description: "Proceed to product search after account is confirmed"
                available when @variables.account_confirmed == True

            back: @utils.transition to @subagent.agent_router
                description: "Go back to main menu"

subagent product_search:
    label: "Product Search & Add to Cart"
    description: "Search for products and add them to the shopping cart"

    actions:
        search_products:
            description: "Search for products using semantic search on the external pricing MCP server"
            target: "apex://ProductSearchAction"
            inputs:
                query: string
                    description: "Semantic search query to find products (e.g. 'heavy duty industrial valve', 'stainless steel pipe fitting')"
                    is_required: True
            outputs:
                results: string
                    description: "JSON string of matching products with names, descriptions, and pricing"
                    is_displayable: True

        get_pricing:
            description: "Get current pricing and details for selected products to add to cart"
            target: "apex://GetPricingAction"
            inputs:
                products: string
                    description: "JSON array of products with quantities to price, e.g. [{sku:CHEM-008,quantity:10}]"
                    is_required: True
            outputs:
                pricedItems: string
                    description: "JSON array of priced items with unitPrice, lineTotal, and updated descriptions"
                    is_displayable: True

        add_to_cart:
            description: "Add priced items to the shopping cart and update cart total"
            target: "apex://AddToCartAction"
            inputs:
                cartItems: string
                    description: "JSON array of priced items to add [{sku, productName, description, quantity, unitPrice, lineTotal}]"
                    is_required: True
                currentCart: string
                    description: "The current cart contents JSON (pass the shopping_cart variable)"
                    is_required: False
            outputs:
                updatedCart: string
                    description: "The updated shopping cart with all items and new grand total"
                    is_displayable: True

        remove_from_cart:
            description: "Remove an item from the shopping cart by SKU"
            target: "apex://RemoveFromCartAction"
            inputs:
                sku: string
                    description: "The SKU of the product to remove"
                    is_required: True
                currentCart: string
                    description: "The current cart contents JSON (pass the shopping_cart variable)"
                    is_required: True
            outputs:
                updatedCart: string
                    description: "The updated shopping cart after removal"
                    is_displayable: True

        update_cart_quantity:
            description: "Update the quantity of an item in the shopping cart"
            target: "apex://UpdateCartQuantityAction"
            inputs:
                sku: string
                    description: "The SKU of the product to update"
                    is_required: True
                newQuantity: object
                    description: "The new quantity for this product"
                    is_required: True
                    complex_data_type_name: "lightning__integerType"
                currentCart: string
                    description: "The current cart contents JSON (pass the shopping_cart variable)"
                    is_required: True
            outputs:
                updatedCart: string
                    description: "The updated shopping cart with recalculated totals"
                    is_displayable: True

        view_cart:
            description: "View the current shopping cart"
            target: "apex://ViewCartAction"
            inputs:
                currentCart: string
                    description: "The current cart contents JSON (pass the shopping_cart variable)"
                    is_required: False
            outputs:
                cartSummary: string
                    description: "Current cart contents with quantities, prices, and grand total"
                    is_displayable: True

    reasoning:
        instructions: ->
            if @variables.json_mode == True:
                | **OUTPUT FORMAT: VALID JSON ONLY - STRICT SCHEMA**
                  You MUST respond ONLY with valid JSON in this exact structure:

                  For type "product_search":
                  {
                    "type": "product_search",
                    "message": "Brief message only (no product details)",
                    "data": [ { "sku": "...", "name": "...", "description": "...", "price": number } ],
                    "actions": ["add_to_cart", "search_products"]
                  }

                  For type "product_search" with no results:
                  {
                    "type": "product_search",
                    "message": "No products found matching '[search term]'. Try different keywords?",
                    "data": [],
                    "actions": ["search_products"]
                  }

                  For type "cart_update":
                  {
                    "type": "cart_update",
                    "message": "Brief message only (no pricing details)",
                    "data": {
                      "items": [ { "sku": "...", "name": "...", "quantity": number, "unitPrice": number, "lineTotal": number } ],
                      "grandTotal": number
                    },
                    "actions": ["view_cart", "add_more_products", "update_cart_quantity", "remove_from_cart", "proceed_to_quote"]
                  }

                  FIELD REQUIREMENTS:
                  - Always use "items" array (never "products" or "cart")
                  - Always use "unitPrice" (never "unit_price")
                  - Always use "lineTotal" (never "subtotal")
                  - Always use camelCase (never snake_case)
                  - Always use "grandTotal" (never "grand_total")
                  - NEVER fabricate products or SKUs - only show what search returned
                  Place ALL text in "message". Place ALL data in "data" object.
                  Do NOT include any text outside of JSON.

            if @variables.json_mode == False:
                | **OUTPUT FORMAT: PLAINTEXT - FULLY ENUMERATED WITH ALL DETAILS**
                  You MUST enumerate EVERY product result with complete formatting.
                  NEVER embed JSON. NEVER say "results shown" without showing them.

                  IMPORTANT: Products are filtered by relevance at the backend (score >= 0.70).
                  If search returns error or empty, report: "No products found matching '[search term]'. Try different keywords?"

                  FORMATTING REQUIREMENTS:
                  - Header: "I found [N] products matching '[search term]':"
                  - One blank line after header
                  - For EACH product (numbered 1, 2, 3, etc.):
                    1. Product Name (SKU)
                       Description text here.
                    - One blank line between products
                  - Footer: Ask user which products and quantities

                  EXACT EXAMPLE (copy this format):
                  "I found 3 products matching 'ammonia':

                  1. Ammonia Solution 25% (CHEM-008)
                     Aqueous ammonia, cleaning and fertilizer base.

                  2. Ammonium Nitrate (CHEM-052)
                     Fertilizer and industrial oxidizer.

                  3. Ammonium Hydroxide 28% (CHEM-045)
                     Aqueous ammonia, cleaning and lab.

                  Which products would you like to add? (e.g., 1:5 for 5 units of product 1)"

                  CRITICAL RULES:
                  - List EVERY result returned - no exceptions
                  - Number each one sequentially starting at 1
                  - Show Name (SKU) and Description for each
                  - Use blank lines between entries for readability
                  - Do NOT embed JSON format - ZERO TOLERANCE
                  - Do NOT embed JSON in cart updates - ZERO TOLERANCE
                  - Do NOT show @outputs variables as-is if they contain JSON
                  - Do NOT omit any results
                  - Do NOT say results shown without showing every one
                  - Do NOT promise data not displayed
                  - Do NOT fabricate products or SKUs - if you don't see it in results, don't show it
                  - If action output contains JSON (updatedCart, pricedItems, etc.), parse it and format as plain text

                  For cart updates: show product names, quantities, unit prices, line totals, and grand total.
                  NEVER show raw JSON blob. Always format as enumerated plaintext when json_mode == False.

            | You help users search for products and manage their shopping cart.
            | CRITICAL RULE: Any time the cart changes (items added, removed, or quantities updated),
              you MUST call {!@actions.get_pricing} immediately to show updated pricing. Do NOT ask
              for confirmation before pricing. The pricing display IS the confirmation.
            | SEARCH: Use {!@actions.search_products} to find products by name/description.
              If @variables.json_mode == True:
                Put product results ONLY in the "data" field as JSON array.
                Put brief prompt in "message" field. Do NOT list in message.
              If @variables.json_mode == False:
                Enumerate ALL products directly in message with Name, SKU, Description.
                Do NOT embed JSON. Show every result found.
            | ADD TO CART: When the user specifies products and quantities, immediately call
              {!@actions.get_pricing} to get pricing, then call {!@actions.add_to_cart} with the priced items.
              If @variables.json_mode == True:
                Return the @outputs.updatedCart as JSON only (structured format).
              If @variables.json_mode == False:
                Parse @outputs.updatedCart and format as plaintext. NEVER embed or show raw JSON.
                Format: "Your cart has been updated for [AccountName]:" then list each item with blank lines:
                [Product Name] ([SKU]) Quantity: [qty] Unit Price: $[price] Line Total: $[total]
                Then show: "Grand Total: $[total]" followed by next steps.
            | MANAGE CART: When user adjusts quantities or removes items:
              - Use {!@actions.update_cart_quantity} or {!@actions.remove_from_cart}
              - Then ALWAYS call {!@actions.get_pricing} again with the full updated cart
              - If json_mode: return as JSON
              - If NOT json_mode: format as plaintext with enumerated items and NO embedded JSON
            | CHECKOUT: When user asks for a quote, transition to quote_generation subagent.
              Never ask "is this correct?" before pricing. Always show pricing immediately.

        actions:
            search: @actions.search_products
                description: "Search for products"
                with query = ...
                set @variables.product_search_results = @outputs.results

            price: @actions.get_pricing
                description: "Get pricing for selected products"
                with products = ...
                set @variables.product_search_results = @outputs.pricedItems

            add: @actions.add_to_cart
                description: "Add priced items to cart"
                with cartItems = ...
                with currentCart = @variables.shopping_cart
                set @variables.shopping_cart = @outputs.updatedCart
                set @variables.cart_empty = False

            remove: @actions.remove_from_cart
                description: "Remove item from cart"
                with sku = ...
                with currentCart = @variables.shopping_cart
                set @variables.shopping_cart = @outputs.updatedCart

            update_qty: @actions.update_cart_quantity
                description: "Update quantity of item in cart"
                with sku = ...
                with newQuantity = ...
                with currentCart = @variables.shopping_cart
                set @variables.shopping_cart = @outputs.updatedCart

            view: @actions.view_cart
                description: "View current cart"
                with currentCart = @variables.shopping_cart
                set @variables.shopping_cart = @outputs.cartSummary

            to_checkout: @utils.transition to @subagent.quote_generation
                description: "Proceed to quote generation when user wants to create a quote"

            to_account: @utils.transition to @subagent.account_selection
                description: "Go back to account selection"

            back: @utils.transition to @subagent.agent_router
                description: "Go back to main menu"

subagent quote_generation:
    label: "Quote Generation & Management"
    description: "Finalize pricing, save quotes to Salesforce, and view quote history"

    actions:
        get_final_pricing:
            description: "Get final pricing for all items in shopping cart (prices may have changed)"
            target: "apex://GetPricingAction"
            inputs:
                products: string
                    description: "JSON array of products in cart with current quantities"
                    is_required: True
            outputs:
                pricedItems: string
                    description: "Final priced items with current unit prices and totals"
                    is_displayable: True

        create_and_save_quote:
            description: "Create quote from cart and save to Salesforce"
            target: "apex://GenerateAndSaveQuote"
            inputs:
                products: string
                    description: "JSON array of final priced items to include in quote"
                    is_required: True
                accountId: string
                    description: "The Salesforce Account ID for this quote"
                    is_required: True
                quoteName: string
                    description: "A name for the quote record"
                    is_required: True
                description: string
                    description: "Executive summary for the quote record: include account name, product names with quantities, grand total, and use case context. 2-3 sentences max."
                    is_required: True
            outputs:
                quoteDetails: string
                    description: "Formatted quote with product details, quantities, prices, and grand total"
                    is_displayable: True
                quoteId: string
                    description: "The ID of the created Quote record in Salesforce"
                    is_displayable: True
                quoteNumber: string
                    description: "The Salesforce-generated quote number"
                    is_displayable: True

        clear_cart:
            description: "Clear the shopping cart after quote is created"
            target: "apex://ClearCartAction"
            inputs:
                confirm: string
                    description: "Pass 'yes' to confirm clearing the cart"
                    is_required: False
            outputs:
                status: string
                    description: "Confirmation that cart has been cleared"
                    is_displayable: True

        get_quote_history:
            description: "Retrieve quote history for an account from Salesforce"
            target: "apex://QuoteHistoryAction"
            inputs:
                accountId: string
                    description: "The Salesforce Account ID to retrieve quotes for"
                    is_required: True
            outputs:
                quotes: string
                    description: "JSON string of quotes with their status, amounts, and dates"
                    is_displayable: True

        get_quote_details:
            description: "Get detailed information about a specific quote"
            target: "apex://QuoteDetailsAction"
            inputs:
                quoteId: string
                    description: "The Quote record ID"
                    is_required: True
            outputs:
                quoteDetail: string
                    description: "Full quote details including products, amounts, and status"
                    is_displayable: True

    reasoning:
        instructions: ->
            if @variables.json_mode == True:
                | **OUTPUT FORMAT: VALID JSON ONLY - STRICT SCHEMA**
                  You MUST respond ONLY with valid JSON in this exact structure:
                  {"type": "pricing|quote_confirm|quote_created", "message": "...", "data": {...}, "actions": [...]}

                  For type "pricing" (final pricing before quote name):
                  {
                    "type": "pricing",
                    "message": "Short message only (< 150 chars)",
                    "data": {
                      "accountName": "Account name",
                      "items": [ { "sku": "...", "name": "...", "quantity": number, "unitPrice": number, "lineTotal": number } ],
                      "grandTotal": number,
                      "currency": "USD"
                    },
                    "actions": ["create_quote", "update_cart_quantity", "remove_from_cart", "view_cart"]
                  }

                  For type "quote_created" (after successful creation):
                  {
                    "type": "quote_created",
                    "message": "Confirmation message",
                    "data": {
                      "quoteNumber": "Quote number string",
                      "quoteId": "Quote ID string",
                      "quoteName": "Quote name",
                      "accountName": "Account name",
                      "items": [ { "sku": "...", "name": "...", "quantity": number, "unitPrice": number, "lineTotal": number } ],
                      "grandTotal": number,
                      "currency": "USD"
                    },
                    "actions": ["create_quote", "view_history", "back"]
                  }

                  FIELD REQUIREMENTS:
                  - Always use "items" array (never "products" or "breakdown")
                  - Always use "unitPrice" (never "unit_price")
                  - Always use "lineTotal" (never "subtotal")
                  - Always use camelCase (never snake_case)
                  Place ALL text in "message". Place ALL data in "data" object.
                  Do NOT include any text outside of JSON.

            if @variables.json_mode == False:
                | Respond naturally with clear, formatted text.
                  Show final pricing with product names, quantities, unit prices, line totals, and grand total.
                  Include quote ID and quote number when displaying saved quotes.

            | You handle quote generation and quote management. Follow this flow:
            | CREATING A QUOTE:
            | STEP 1 - FINAL PRICING: Use {!@actions.get_final_pricing} with all items currently in the cart.
              IMPORTANT: When showing final pricing (type: "pricing"), use a SHORT message like:
              "Here's your quote summary. Enter a name and click Create Quote to proceed."
              Do NOT repeat product names, quantities, or prices in the message - the UI will display all details.
            | STEP 2 - CONFIRM: Ask user for a quote name and confirm they're ready to create.
            | STEP 3 - CREATE AND SAVE: Use {!@actions.create_and_save_quote} with products, accountId, quoteName,
              and a description. For the description, write a rich 2-3 sentence executive summary that includes:
              the account name, each product name with its quantity, the grand total, and the business context
              (e.g. what the chemicals are used for).
              Then respond with type: "quote_created" including quoteNumber, quoteId, accountName, grandTotal, currency, and breakdown array.
            | STEP 4 - CLEAR CART: Use {!@actions.clear_cart} to empty the shopping cart. Confirm quote saved and cart cleared.
            | VIEWING QUOTES: Use {!@actions.get_quote_history} to show past quotes. Use {!@actions.get_quote_details} for full details.
            | After any operation, offer to create another quote, view history, or go back.

        actions:
            final_price: @actions.get_final_pricing
                description: "Get final pricing for cart items"
                with products = ...
                set @variables.product_search_results = @outputs.pricedItems

            create: @actions.create_and_save_quote
                description: "Create and save quote"
                with products = ...
                with accountId = ...
                with quoteName = ...
                with description = ...
                set @variables.quote_description = @outputs.quoteDetails
                set @variables.quote_id = @outputs.quoteId
                set @variables.quote_number = @outputs.quoteNumber

            clear: @actions.clear_cart
                description: "Clear the cart after quote creation"
                set @variables.shopping_cart = ""
                set @variables.cart_empty = True
                set @variables.cart_item_count = 0

            history: @actions.get_quote_history
                description: "View quote history for the current account"
                with accountId = @variables.account_id

            details: @actions.get_quote_details
                description: "View details of a specific quote"
                with quoteId = ...

            new_quote: @utils.transition to @subagent.product_search
                description: "Create another quote with the current account"

            back: @utils.transition to @subagent.agent_router
                description: "Go back to main menu"

