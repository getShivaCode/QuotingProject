# OAuth Configuration for Salesforce
SF_CLIENT_ID=your_client_id_here
SF_CLIENT_SECRET=your_client_secret_here
SF_REDIRECT_URI=http://localhost:3001/oauth/callback
SF_INSTANCE_URL=https://your-instance.my.salesforce.com
SF_API_VERSION=v61.0

# Salesforce Agent API Configuration
SF_ACCESS_TOKEN=your_access_token_here
SF_AGENT_NAME=Quoting_Agent
SF_AGENT_ID=your_agent_id_here
SF_ORG_ID=your_org_id_here

# App Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=warning

# External App Configuration
EXTERNAL_APP_SECRET=your_external_app_secret_here
EXTERNAL_APP_KEY=your_external_app_key_here
